#include <winver.h>

1 ICON "@CMAKE_CURRENT_SOURCE_DIR@/src/dcmake.ico"

VS_VERSION_INFO VERSIONINFO
    FILEVERSION    @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
    PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
    FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
    FILEFLAGS      0
    FILEOS         VOS_NT_WINDOWS32
    FILETYPE       VFT_APP
    FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "Christopher Wellons"
            VALUE "FileDescription",  "A debugger for CMake"
            VALUE "FileVersion",      "@PROJECT_VERSION@"
            VALUE "InternalName",     "dcmake"
            VALUE "LegalCopyright",   "Public domain"
            VALUE "OriginalFilename", "dcmake.exe"
            VALUE "ProductName",      "dcmake"
            VALUE "ProductVersion",   "@PROJECT_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END
